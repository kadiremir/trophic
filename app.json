{
  "expo": {
    "name": "Trophic",
    "slug": "trophic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#070b06"
    },
    "ios": {
